{
  "name": "@vela/mobile",
  "version": "0.0.1",
  "description": "Vela Mobile - iOS Japanese Learning App",
  "productName": "Vela",
  "author": "cwchanap <cwchanap@connect.ust.hk>",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "dev:ios": "quasar dev -m capacitor -T ios",
    "build": "quasar build",
    "build:ios": "quasar build -m capacitor -T ios",
    "lint": "eslint \"./src/**/*.{ts,js,vue}\"",
    "lint:fix": "eslint \"./src/**/*.{ts,js,vue}\" --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path ../../.gitignore",
    "test:unit": "vitest run",
    "test": "bun run test:unit",
    "typecheck": "vue-tsc --noEmit",
    "postinstall": "quasar prepare && bun install --cwd src-capacitor",
    "clean": "rm -rf dist .quasar"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "quasar": "^2.16.0",
    "vue": "^3.4.18",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@quasar/app-vite": "^2.4.0",
    "@quasar/vite-plugin": "^1.8.0",
    "@types/node": "^20.5.9",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "~5.6.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.0.29"
  },
  "engines": {
    "bun": ">= 1.3.1"
  }
}
