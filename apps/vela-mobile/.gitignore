# Capacitor generated assets (regenerated by cap sync)
src-capacitor/www/
src-capacitor/node_modules/

# iOS build artifacts (project itself IS committed)
src-capacitor/ios/App/Pods/
src-capacitor/ios/App/build/
src-capacitor/ios/App/output/
src-capacitor/ios/App/App/public/
src-capacitor/ios/App/App/capacitor.config.json
src-capacitor/ios/App/App.xcodeproj/xcuserdata/
src-capacitor/ios/App/App.xcworkspace/xcuserdata/
src-capacitor/ios/DerivedData/
src-capacitor/ios/App/exported/

# Quasar
.quasar
dist/

# Test coverage
coverage/

# Env files (consumed by scripts/sync-ios-version.mjs and Quasar app-vite).
# Quasar app-vite loads .env, .env.local, .env.[dev|prod], .env.[capacitor],
# .env.[dev|prod].[capacitor] and their .local.* variants — see
# node_modules/@quasar/app-vite/lib/utils/env.js. Ignore every variant so
# local config and secrets can't be accidentally committed; keep .env.example.
.env
.env.*
!.env.example
