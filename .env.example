# AWS Cognito Configuration
VITE_COGNITO_USER_POOL_ID=your_cognito_user_pool_id_here
VITE_COGNITO_USER_POOL_CLIENT_ID=your_cognito_user_pool_client_id_here
VITE_COGNITO_OAUTH_DOMAIN=vela-local-auth.auth.us-east-1.amazoncognito.com
# Redirect values may be comma-separated when multiple callback/logout URLs are needed.
VITE_COGNITO_REDIRECT_SIGN_IN=http://localhost:9000/auth/callback
VITE_COGNITO_REDIRECT_SIGN_OUT=http://localhost:9000/auth/login
VITE_AWS_REGION=your_aws_region_here

# AWS Credentials (required for API server to validate Cognito tokens)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# AI Service Configuration
VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_GEMINI_API_KEY=your_google_gemini_api_key_here
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# App Configuration
VITE_APP_NAME=Vela
VITE_APP_VERSION=1.0.0

# API Base URL (frontend -> backend proxy). Defaults to '/api/' if not set.
VITE_API_URL=http://localhost:3001/api/
# API CORS allowlists. Extension IDs are the bare IDs without chrome-extension://.
CORS_ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000
CORS_ALLOWED_EXTENSION_IDS=your_chrome_extension_id_here,your_firefox_extension_id_here

# Development Configuration
VITE_DEV_MODE=true

# Optional: Local DynamoDB settings used by experimental client-only service (not required)
# The production/official integration uses server-side environment
VITE_DDB_ENDPOINT=http://127.0.0.1:8000
VITE_DDB_REGION=local
VITE_DDB_TABLE=VelaChatMessages

# Playwright E2E test credentials
TEST_EMAIL=your_test_account_email_here
TEST_PASSWORD=your_test_account_password_here
# Cognito client that allows AdminInitiateAuth (used by Playwright fixtures to bypass Google OAuth UI)
VITE_COGNITO_TEST_CLIENT_ID=your_cognito_test_client_id_here
