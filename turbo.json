{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", ".output/**", "!.next/cache/**"],
      "env": [
        "VITE_APP_NAME",
        "VITE_APP_VERSION",
        "VITE_DEV_MODE",
        "VITE_API_URL",
        "VITE_AWS_REGION",
        "VITE_COGNITO_USER_POOL_ID",
        "VITE_COGNITO_USER_POOL_CLIENT_ID",
        "VITE_COGNITO_OAUTH_DOMAIN",
        "VITE_COGNITO_REDIRECT_SIGN_IN",
        "VITE_COGNITO_REDIRECT_SIGN_OUT"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        ".env.production",
        ".env.production.local"
      ]
    },
    "zip": {
      "dependsOn": ["^build"],
      "outputs": [".output/*.zip"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:extension-test": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": ["test-results/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["playwright-report/**"]
    },
    "test:headed": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:ui": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:debug": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "cdk:synth": {
      "dependsOn": ["^build"]
    },
    "cdk:deploy": {
      "dependsOn": ["^build", "cdk:synth"]
    },
    "cdk:diff": {
      "dependsOn": ["^build"]
    },
    "cdk:destroy": {},
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
